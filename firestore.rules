rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isProjectOwner(projectId) {
      return signedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
    }

    match /projects/{projectId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isProjectOwner(projectId);

      match /applications/{uid} {
        allow read: if signedIn();
        allow create, update: if isSelf(uid) || isProjectOwner(projectId);
      }

      match /members/{uid} {
        allow read: if signedIn();
        allow create: if isProjectOwner(projectId);
        allow update: if isProjectOwner(projectId) && !(request.resource.data.memberStatus == 'removed' && resource.data.memberStatus != 'removal_pending');
      }

      match /channels/{channelId} {
        allow read: if signedIn();
        allow create, update: if isProjectOwner(projectId);

        match /messages/{messageId} {
          allow read: if signedIn();
          allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
          allow update: if false;
        }
      }

      match /contracts/{contractId} {
        allow read: if signedIn();
        allow write: if false;
      }

      match /governance/{doc=**} {
        allow read: if signedIn();
        allow write: if false;
      }

      match /distributionRuns/{runId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }
  }
}
